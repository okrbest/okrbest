## Group 모델

```go
// server/public/model/group.go
type Group struct {
    Id                          string      `json:"id"`
    Name                        *string     `json:"name,omitempty"`
    DisplayName                 string      `json:"display_name"`
    Description                 string      `json:"description"`
    Source                      GroupSource `json:"source"`
    RemoteId                    *string     `json:"remote_id"`
    CreateAt                    int64       `json:"create_at"`
    UpdateAt                    int64       `json:"update_at"`
    DeleteAt                    int64       `json:"delete_at"`
    HasSyncables                bool        `json:"has_syncables"`       // db:"-"
    MemberCount                 *int        `json:"member_count,omitempty"`    // db:"-"
    AllowReference              bool        `json:"allow_reference"`
    ChannelMemberCount          *int        `json:"channel_member_count,omitempty"`  // db:"-"
    ChannelMemberTimezonesCount *int        `json:"channel_member_timezones_count,omitempty"` // db:"-"
    MemberIDs                   []string    `json:"member_ids"`          // db:"-"
}

type GroupSource string

const (
    GroupSourceLdap         GroupSource = "ldap"
    GroupSourceCustom       GroupSource = "custom"
    GroupSourcePluginPrefix GroupSource = "plugin_"  // 플러그인 그룹은 이 접두사 사용
)
```

