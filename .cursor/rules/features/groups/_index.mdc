| `/api/v4/groups/{group_id}/channels/{channel_id}/link` | POST | 그룹-채널 연동 |

## LDAP 그룹 동기화

```go
// LDAP에서 그룹 동기화
func (a *App) SyncLdapGroups() *model.AppError {
    // 1. LDAP 연결
    ldap := a.Ldap()
    if ldap == nil {
        return model.NewAppError(...)
    }
    
    // 2. LDAP 그룹 조회
    ldapGroups, err := ldap.GetAllGroups()
    if err != nil {
        return err
    }
    
    // 3. 로컬 그룹과 비교 및 동기화
    for _, lg := range ldapGroups {
        group, err := a.GetGroupByRemoteId(lg.RemoteId, model.GroupSourceLdap)
        if err != nil {
            // 새 그룹 생성
            a.CreateGroup(&model.Group{
                Name:        &lg.Name,
                DisplayName: lg.DisplayName,
                Source:      model.GroupSourceLdap,
                RemoteId:    &lg.RemoteId,
            })
        } else {
            // 기존 그룹 업데이트
            a.UpdateGroup(group)
        }
        
        // 멤버십 동기화
        a.syncGroupMembers(group, lg.Members)
    }
    
    return nil
}
```

## 그룹 멘션

```go
// @그룹명으로 그룹 멘션 (예: @engineering)
func (a *App) GetGroupsForReferenceParsing() ([]*model.Group, *model.AppError) {
    // AllowReference가 true인 그룹만 조회
    groups, err := a.Srv().Store().Group().GetAllBySource(model.GroupSourceCustom)
    
    var refGroups []*model.Group
    for _, g := range groups {
        if g.AllowReference {
            refGroups = append(refGroups, g)
        }
    }
    
    return refGroups, nil
}
```

## 자동 멤버십 추가

```go
// AutoAdd가 true인 경우 그룹 멤버는 자동으로 팀/채널에 추가
func (a *App) AddGroupMemberToSyncables(userId, groupId string) {
    syncables, _ := a.GetGroupSyncables(groupId)
    
    for _, sync := range syncables {
        if sync.AutoAdd {
            if sync.SyncableType == model.GroupSyncableTypeTeam {
                a.AddTeamMember(rctx, sync.SyncableId, userId)
            } else if sync.SyncableType == model.GroupSyncableTypeChannel {
                a.AddChannelMember(rctx, userId, sync.SyncableId, ...)
            }
        }
    }
}
```

