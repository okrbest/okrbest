## 온보딩 진행률

```go
// 튜토리얼 단계 저장 (Preferences 사용)
func (a *App) GetTutorialStep(userId string) (int, *model.AppError) {
    pref, err := a.GetPreferenceByCategoryAndNameForUser(userId, model.PreferenceCategoryTutorialSteps, userId)
    if err != nil {
        return 0, err
    }
    
    step, _ := strconv.Atoi(pref.Value)
    return step, nil
}

func (a *App) SetTutorialStep(userId string, step int) *model.AppError {
    return a.UpdatePreferences(userId, model.Preferences{
        {
            UserId:   userId,
            Category: model.PreferenceCategoryTutorialSteps,
            Name:     userId,
            Value:    strconv.Itoa(step),
        },
    })
}
```

## 체크리스트 태스크

```typescript
// 온보딩 체크리스트
interface OnboardingTask {
    id: string;
    title: string;
    completed: boolean;
    action: () => void;
}

const tasks: OnboardingTask[] = [
    {
        id: 'complete_profile',
        title: '프로필 완성하기',
        completed: user.hasProfilePicture,
        action: () => openProfileSettings(),
    },
    {
        id: 'invite_members',
        title: '팀원 초대하기',
        completed: teamMemberCount > 1,
        action: () => openInviteModal(),
    },
    {
        id: 'download_apps',
        title: '앱 다운로드',
        completed: false,
        action: () => openAppDownload(),
    },
];
```

