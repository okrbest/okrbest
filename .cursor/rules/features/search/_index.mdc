}
```

## 검색 결과 하이라이트

```typescript
// 웹앱에서 검색어 하이라이트
const highlightSearchTerms = (message: string, searchTerms: string[]) => {
    let result = message;
    searchTerms.forEach(term => {
        const regex = new RegExp(`(${escapeRegex(term)})`, 'gi');
        result = result.replace(regex, '<span class="search-highlight">$1</span>');
    });
    return result;
};
```

