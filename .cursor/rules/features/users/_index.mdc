## 사용자 생성 흐름

```go
// server/channels/app/user.go
func (a *App) CreateUser(user *model.User) (*model.User, *model.AppError) {
    // 1. 유효성 검사
    if err := user.IsValid(); err != nil {
        return nil, err
    }
    
    // 2. 비밀번호 해싱
    user.Password = model.HashPassword(user.Password)
    
    // 3. DB 저장
    ruser, err := a.Srv().Store().User().Save(user)
    if err != nil {
        return nil, err
    }
    
    // 4. 환영 메시지 전송 (설정에 따라)
    if *a.Config().EmailSettings.SendEmailNotifications {
        a.sendWelcomeEmail(ruser)
    }
    
    return ruser, nil
}
```

## 인증 흐름

```go
// server/channels/app/authentication.go
func (a *App) AuthenticateUserForLogin(loginId, password string) (*model.User, *model.AppError) {
    // 1. 사용자 조회 (email 또는 username)
    user, err := a.GetUserForLogin(loginId)
    if err != nil {
        return nil, err
    }
    
    // 2. 계정 잠금 확인
    if user.IsLocked() {
        return nil, model.NewAppError(...)
    }
    
    // 3. 비밀번호 검증
    if !model.ComparePassword(user.Password, password) {
        a.updateFailedAttempts(user)
        return nil, model.NewAppError(...)
    }
    
    // 4. MFA 확인 (활성화된 경우)
    if user.MfaActive {
        // MFA 토큰 검증 필요
    }
    
    return user, nil
}
```

